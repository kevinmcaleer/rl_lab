Panels:
  - Class: rviz_common/3D
    Name: 3D View
    Fixed Frame: world
    Background Color: 48; 48; 48
    Displays:
      - Class: rviz_default_plugins/Grid
        Name: Grid
        Enabled: true
        Reference Frame: <Fixed Frame>
        Plane: XY
        Normal Cell Count: 0
        Cell Size: 0.05
        Line Style:
          Line Width: 0.03
          Value: Lines
        Color: 160; 160; 164
        Alpha: 0.5
        Offset:
          X: 0
          Y: 0
          Z: 0
        Plane Cell Count: 10

      - Class: rviz_default_plugins/RobotModel
        Name: RobotModel
        Enabled: true
        # The URDF is loaded from the /robot_description parameter published by
        # robot_state_publisher.  See docs/getting_started/installation_ros2.md.
        Description Source: Topic
        Description Topic: /robot_description
        Alpha: 1
        Robot Description Topic: /robot_description
        TF Prefix: ""
        Visual Enabled: true
        Collision Enabled: false
        Update Interval: 0
        Links:
          All Links Enabled: true
          Expand Joint Details: false
          Expand Link Details: false
          Expand Tree: false
          Link Tree Style: Links in Alphabetic Order

      - Class: rviz_default_plugins/TF
        Name: TF
        Enabled: true
        Marker Scale: 0.1
        Update Interval: 0
        Show Arrows: true
        Show Axes: true
        Show Names: true
        Frames:
          All Enabled: true
        Tree:
          {}

      - Class: rviz_default_plugins/Marker
        Name: TargetMarker
        Enabled: true
        # Topic published by ROS2Publisher._publish_target_marker()
        Marker Topic: /target_marker
        Queue Size: 5
        Namespaces:
          rl_lab: true

Visualization Manager:
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: world
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0

Window Geometry:
  3D View:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Width: 1280
  X: 0
  Y: 27
